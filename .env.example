# --- Server ---
PORT=3000
APP_BASE_URL=http://localhost:3000

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# --- Etsy OAuth / API ---
# Register an Etsy app and set the same redirect URI in Etsy app settings.
# Etsy requires OAuth2 Authorization Code + PKCE, and redirect URI matching exactly.
ETSY_CLIENT_ID=your_etsy_keystring
# Some Etsy docs/examples show x-api-key as keystring:sharedsecret. Put the exact value you want sent.
ETSY_X_API_KEY=your_etsy_keystring:your_etsy_shared_secret
ETSY_REDIRECT_URI=https://your-https-domain.example.com/auth/etsy/callback

# Optional defaults (can also be set in the UI and stored locally)
# SYNC_FOLDER=C:\\Users\\you\\OneDrive\\Mug Photos
