# Etsy Draft Listing Assistant — environment configuration
# This file is auto-copied to %APPDATA%\Etsy Draft Listing Assistant\.env on first launch.
# Edit that copy to fill in your keys, then restart the app.

# --- Server ---
PORT=3000
APP_BASE_URL=http://localhost:3000

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Etsy OAuth / API ---
# Register an Etsy developer app at https://www.etsy.com/developers/your-apps
# The redirect URI must EXACTLY match what is set there.
ETSY_CLIENT_ID=
ETSY_X_API_KEY=
ETSY_REDIRECT_URI=http://localhost:3000/auth/etsy/callback
